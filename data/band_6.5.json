[{"w":"fluctuation","p":"/ˌflʌktʃuˈeɪʃn/","ps":"noun","me":"an irregular variation","mk":"변동","ex":"Investors are concerned about the fluctuation in oil prices over the past month.","et":"투자자들은 지난달 유가의 변동에 대해 우려하고 있다.","t":"business"},{"w":"complement","p":"/ˈkɒmplɪment/","ps":"verb","me":"to add to something to enhance it","mk":"보완하다","ex":"Regular exercise can complement a healthy diet to improve overall well-being.","et":"규칙적인 운동은 건강한 식단을 보완하여 전반적인 건강을 향상시킬 수 있다.","t":"science"},{"w":"constrain","p":"/kənˈstreɪn/","ps":"verb","me":"to severely restrict","mk":"제약하다","ex":"Limited funding continues to constrain the government's ability to expand public services.","et":"제한된 자금은 공공 서비스를 확대하려는 정부의 능력을 계속 제약하고 있다.","t":"science"},{"w":"debilitating","p":"/dɪˈbɪlɪteɪtɪŋ/","ps":"adjective","me":"making someone weak","mk":"쇠약하게 하는","ex":"Chronic fatigue syndrome can be debilitating, making it hard for patients to work.","et":"만성 피로 증후군은 쇠약하게 하여 환자들이 일하기 어렵게 만들 수 있다.","t":"health"},{"w":"depreciate","p":"/dɪˈpriːʃieɪt/","ps":"verb","me":"to diminish in value over time","mk":"감가상각하다","ex":"New cars typically depreciate in value by around 20% within the first year.","et":"새 차는 보통 첫 해 안에 가치가 약 20% 감가상각된다.","t":"business"},{"w":"divergent","p":"/daɪˈvɜːrdʒənt/","ps":"adjective","me":"tending to be different","mk":"상이한, 갈라지는","ex":"The two scientists held divergent views on the causes of the recent epidemic.","et":"두 과학자는 최근 전염병의 원인에 대해 서로 다른 견해를 가지고 있었다.","t":"science"},{"w":"enhance","p":"/ɪnˈhæns/","ps":"verb","me":"to intensify or improve","mk":"향상시키다","ex":"Adding visuals to a presentation can greatly enhance the audience's understanding.","et":"프레젠테이션에 시각 자료를 추가하면 청중의 이해를 크게 향상시킬 수 있다.","t":"technology"},{"w":"epitomize","p":"/ɪˈpɪtəmaɪz/","ps":"verb","me":"to be a perfect example of","mk":"전형이 되다","ex":"Nelson Mandela is often said to epitomize courage and dedication to justice.","et":"넬슨 만델라는 용기와 정의에 대한 헌신을 전형적으로 보여준다고 종종 말해진다.","t":"culture"},{"w":"ideological","p":"/ˌaɪdiəˈlɒdʒɪkl/","ps":"adjective","me":"based on a particular set of ideas","mk":"이념적인","ex":"The two parties clashed over ideological differences regarding the role of the state.","et":"두 정당은 국가의 역할에 관한 이념적 차이로 충돌했다.","t":"society"},{"w":"illuminate","p":"/ɪˈluːmɪneɪt/","ps":"verb","me":"to light up or clarify","mk":"조명하다","ex":"The documentary sought to illuminate the hidden struggles of migrant workers.","et":"그 다큐멘터리는 이주 노동자들의 숨겨진 어려움을 조명하고자 했다.","t":"education"},{"w":"implicate","p":"/ˈɪmplɪkeɪt/","ps":"verb","me":"to show to be involved","mk":"관련시키다","ex":"The leaked documents implicate several senior officials in the corruption scandal.","et":"유출된 문서들은 부패 스캔들에 여러 고위 관리들을 관련시킨다.","t":"society"},{"w":"inception","p":"/ɪnˈsepʃn/","ps":"noun","me":"the establishment or starting point","mk":"시작","ex":"Since its inception in 2005, the charity has helped over a million people.","et":"2005년 시작 이래로 그 자선 단체는 백만 명 이상의 사람들을 도왔다.","t":"business"},{"w":"incur","p":"/ɪnˈkɜːr/","ps":"verb","me":"to become subject to something unpleasant","mk":"초래하다","ex":"The company incurred heavy losses after its biggest client cancelled the contract.","et":"그 회사는 가장 큰 고객이 계약을 취소한 후 큰 손실을 초래했다.","t":"business"},{"w":"inevitable","p":"/ɪnˈevɪtəbl/","ps":"adjective","me":"certain to happen","mk":"불가피한","ex":"With rising sea levels, flooding in coastal cities seems inevitable without urgent action.","et":"해수면 상승으로 긴급한 조치 없이는 해안 도시의 홍수가 불가피해 보인다.","t":"daily_life"},{"w":"jurisdiction","p":"/ˌdʒʊrɪsˈdɪkʃn/","ps":"noun","me":"the official power to make legal decisions","mk":"관할권","ex":"The crime occurred in international waters, which complicated questions of jurisdiction.","et":"그 범죄는 국제 해역에서 발생하여 관할권 문제를 복잡하게 만들었다.","t":"society"},{"w":"levy","p":"/ˈlevi/","ps":"verb","me":"to impose a tax","mk":"부과하다","ex":"The city council voted to levy an additional tax on luxury goods.","et":"시의회는 명품에 추가 세금을 부과하기로 투표했다.","t":"business"},{"w":"methodology","p":"/ˌmeθəˈdɒlədʒi/","ps":"noun","me":"the body of methods used","mk":"방법론","ex":"The paper was criticised because the research methodology lacked transparency.","et":"그 논문은 연구 방법론이 투명성이 부족하다는 이유로 비판을 받았다.","t":"science"},{"w":"omnipresent","p":"/ˌɒmnɪˈpreznt/","ps":"adjective","me":"widely or constantly encountered","mk":"어디에나 있는","ex":"Social media has become omnipresent, influencing how people communicate and form opinions.","et":"소셜 미디어는 어디에나 존재하게 되어 사람들이 소통하고 의견을 형성하는 방식에 영향을 미친다.","t":"society"},{"w":"acrimony","p":"/ˈækrɪməni/","ps":"noun","me":"bitterness or ill feeling","mk":"신랄함, 앙금","ex":"The debate ended with acrimony.","et":"토론은 적대감으로 끝났다.","t":"society"},{"w":"assert","p":"/əˈsɜːrt/","ps":"verb","me":"to state confidently","mk":"주장하다","ex":"He asserted his right to speak.","et":"그는 발언권을 주장했다.","t":"society"},{"w":"attest","p":"/əˈtest/","ps":"verb","me":"to provide evidence of","mk":"증명하다","ex":"The records attest to his innocence.","et":"기록들이 그의 결백을 증명한다.","t":"society"},{"w":"attribute","p":"/əˈtrɪbjuːt/","ps":"verb","me":"to regard as caused by","mk":"~의 탓으로 돌리다","ex":"They attribute success to hard work.","et":"그들은 성공을 노력 덕으로 돌린다.","t":"education"},{"w":"avert","p":"/əˈvɜːrt/","ps":"verb","me":"to prevent or turn away","mk":"방지하다","ex":"They acted quickly to avert disaster.","et":"그들은 재난을 방지하기 위해 빨리 행동했다.","t":"daily_life"},{"w":"benchmark","p":"/ˈbentʃmɑːrk/","ps":"noun","me":"a standard for comparison","mk":"기준점","ex":"This score sets a new benchmark.","et":"이 점수는 새 기준점을 세운다.","t":"business"},{"w":"bewilder","p":"/bɪˈwɪldər/","ps":"verb","me":"to confuse greatly","mk":"당황하게 하다","ex":"The results bewildered researchers.","et":"결과는 연구자들을 당황하게 했다.","t":"science"},{"w":"collaborate","p":"/kəˈlæbəreɪt/","ps":"verb","me":"to work jointly","mk":"협력하다","ex":"The teams collaborated on the project.","et":"팀들은 프로젝트에 협력했다.","t":"business"},{"w":"conceive","p":"/kənˈsiːv/","ps":"verb","me":"to form an idea","mk":"구상하다","ex":"She conceived a brilliant plan.","et":"그녀는 훌륭한 계획을 구상했다.","t":"education"},{"w":"connote","p":"/kəˈnoʊt/","ps":"verb","me":"to imply in addition to meaning","mk":"함축하다","ex":"The word connotes negative feelings.","et":"그 단어는 부정적 감정을 함축한다.","t":"education"},{"w":"constitute","p":"/ˈkɒnstɪtjuːt/","ps":"verb","me":"to be a part of a whole","mk":"구성하다","ex":"Women constitute half the workforce.","et":"여성은 노동력의 절반을 구성한다.","t":"society"},{"w":"contradict","p":"/ˌkɒntrəˈdɪkt/","ps":"verb","me":"to assert the opposite","mk":"모순되다","ex":"The evidence contradicts the theory.","et":"증거가 이론과 모순된다.","t":"science"},{"w":"contrive","p":"/kənˈtraɪv/","ps":"verb","me":"to create or arrange cleverly","mk":"고안하다","ex":"He contrived a plan to escape.","et":"그는 탈출 계획을 고안했다.","t":"daily_life"},{"w":"convey","p":"/kənˈveɪ/","ps":"verb","me":"to communicate or transport","mk":"전달하다","ex":"The author conveys a strong message.","et":"저자는 강한 메시지를 전달한다.","t":"education"},{"w":"credible","p":"/ˈkredɪbl/","ps":"adjective","me":"able to be believed","mk":"신뢰할 수 있는","ex":"The source is highly credible.","et":"그 출처는 매우 신뢰할 수 있다.","t":"education"},{"w":"deduce","p":"/dɪˈdjuːs/","ps":"verb","me":"to reach a conclusion by reasoning","mk":"추론하다","ex":"We can deduce the answer logically.","et":"우리는 답을 논리적으로 추론할 수 있다.","t":"science"},{"w":"deficiency","p":"/dɪˈfɪʃənsi/","ps":"noun","me":"a lack or shortage","mk":"결핍","ex":"Vitamin deficiency causes health issues.","et":"비타민 결핍은 건강 문제를 일으킨다.","t":"health"},{"w":"degrade","p":"/dɪˈɡreɪd/","ps":"verb","me":"to lower in quality or status","mk":"저하시키다","ex":"Pollution degrades water quality.","et":"오염은 수질을 저하시킨다.","t":"environment"},{"w":"demote","p":"/dɪˈmoʊt/","ps":"verb","me":"to lower in rank","mk":"강등시키다","ex":"He was demoted after the incident.","et":"그는 사건 후 강등되었다.","t":"business"},{"w":"derive","p":"/dɪˈraɪv/","ps":"verb","me":"to obtain from a source","mk":"유래하다","ex":"The word derives from Latin.","et":"그 단어는 라틴어에서 유래한다.","t":"education"},{"w":"designate","p":"/ˈdezɪɡneɪt/","ps":"verb","me":"to officially assign a status","mk":"지정하다","ex":"The area was designated a park.","et":"그 지역은 공원으로 지정되었다.","t":"environment"},{"w":"devise","p":"/dɪˈvaɪz/","ps":"verb","me":"to plan or invent","mk":"고안하다","ex":"Scientists devised a new method.","et":"과학자들은 새로운 방법을 고안했다.","t":"science"},{"w":"devote","p":"/dɪˈvoʊt/","ps":"verb","me":"to give time or resources to","mk":"헌신하다","ex":"She devoted years to the research.","et":"그녀는 수년을 연구에 헌신했다.","t":"education"},{"w":"differentiate","p":"/ˌdɪfəˈrenʃieɪt/","ps":"verb","me":"to distinguish between","mk":"구별하다","ex":"It is hard to differentiate the two.","et":"둘을 구별하기 어렵다.","t":"science"},{"w":"discern","p":"/dɪˈsɜːrn/","ps":"verb","me":"to perceive or recognize","mk":"식별하다","ex":"It is hard to discern the truth.","et":"진실을 식별하기 어렵다.","t":"education"},{"w":"disclose","p":"/dɪsˈkloʊz/","ps":"verb","me":"to make known","mk":"공개하다","ex":"The company disclosed its earnings.","et":"회사는 수익을 공개했다.","t":"business"},{"w":"disrupt","p":"/dɪsˈrʌpt/","ps":"verb","me":"to interrupt the normal course of","mk":"방해하다","ex":"Technology can disrupt traditional industries.","et":"기술은 전통 산업을 방해할 수 있다.","t":"technology"},{"w":"distort","p":"/dɪsˈtɔːrt/","ps":"verb","me":"to give a misleading account","mk":"왜곡하다","ex":"Media can distort public perception.","et":"미디어는 대중 인식을 왜곡할 수 있다.","t":"society"},{"w":"ecological","p":"/ˌiːkəˈlɒdʒɪkl/","ps":"adjective","me":"relating to ecology","mk":"생태학적인","ex":"Ecological balance must be maintained.","et":"생태학적 균형이 유지되어야 한다.","t":"environment"},{"w":"emerge","p":"/ɪˈmɜːrdʒ/","ps":"verb","me":"to come into view","mk":"나타나다","ex":"New trends emerge every decade.","et":"새로운 트렌드가 매 10년마다 나타난다.","t":"society"},{"w":"enrich","p":"/ɪnˈrɪtʃ/","ps":"verb","me":"to improve the quality of","mk":"풍요롭게 하다","ex":"Travel enriches your perspective.","et":"여행은 시각을 풍요롭게 한다.","t":"travel"},{"w":"ethnic","p":"/ˈeθnɪk/","ps":"adjective","me":"relating to a cultural group","mk":"민족의","ex":"Ethnic diversity enriches culture.","et":"민족적 다양성은 문화를 풍요롭게 한다.","t":"culture"},{"w":"evade","p":"/ɪˈveɪd/","ps":"verb","me":"to escape or avoid","mk":"회피하다","ex":"He tried to evade the question.","et":"그는 질문을 회피하려 했다.","t":"daily_life"},{"w":"evolve","p":"/ɪˈvɒlv/","ps":"verb","me":"to develop gradually","mk":"진화하다","ex":"Languages evolve over time.","et":"언어는 시간이 지남에 따라 진화한다.","t":"science"},{"w":"facet","p":"/ˈfæsɪt/","ps":"noun","me":"one side or aspect","mk":"측면","ex":"Every facet of the issue matters.","et":"문제의 모든 측면이 중요하다.","t":"education"},{"w":"fallacy","p":"/ˈfæləsi/","ps":"noun","me":"a mistaken belief","mk":"오류","ex":"That argument contains a logical fallacy.","et":"그 주장은 논리적 오류를 포함한다.","t":"education"},{"w":"finite","p":"/ˈfaɪnaɪt/","ps":"adjective","me":"having limits","mk":"유한한","ex":"Natural resources are finite.","et":"천연자원은 유한하다.","t":"environment"},{"w":"foreseeable","p":"/fɔːrˈsiːəbl/","ps":"adjective","me":"able to be predicted","mk":"예측 가능한","ex":"No change in the foreseeable future.","et":"예측 가능한 미래에 변화가 없다.","t":"daily_life"},{"w":"forthcoming","p":"/ˌfɔːrθˈkʌmɪŋ/","ps":"adjective","me":"about to happen","mk":"다가오는","ex":"The forthcoming election is crucial.","et":"다가오는 선거가 중요하다.","t":"society"},{"w":"formulate","p":"/ˈfɔːrmjʊleɪt/","ps":"verb","me":"to create or devise methodically","mk":"공식화하다","ex":"They formulated a new strategy.","et":"그들은 새로운 전략을 공식화했다.","t":"business"},{"w":"generic","p":"/dʒəˈnerɪk/","ps":"adjective","me":"relating to a class or group","mk":"일반적인","ex":"Use the generic term instead.","et":"대신 일반적인 용어를 사용하라.","t":"science"},{"w":"grave","p":"/ɡreɪv/","ps":"adjective","me":"serious and worrying","mk":"심각한","ex":"The situation is extremely grave.","et":"상황은 극도로 심각하다.","t":"society"},{"w":"groundbreaking","p":"/ˈɡraʊndbreɪkɪŋ/","ps":"adjective","me":"innovative and pioneering","mk":"획기적인","ex":"It was a groundbreaking discovery.","et":"그것은 획기적인 발견이었다.","t":"science"},{"w":"harness","p":"/ˈhɑːrnɪs/","ps":"verb","me":"to control and use a resource","mk":"활용하다","ex":"We must harness renewable energy.","et":"우리는 재생 에너지를 활용해야 한다.","t":"environment"},{"w":"heed","p":"/hiːd/","ps":"verb","me":"to pay attention to","mk":"주의를 기울이다","ex":"We should heed expert warnings.","et":"우리는 전문가 경고에 주의를 기울여야 한다.","t":"daily_life"},{"w":"humanitarian","p":"/hjuːˌmænɪˈteəriən/","ps":"adjective","me":"concerned with human welfare","mk":"인도주의적인","ex":"The crisis demands humanitarian aid.","et":"위기는 인도주의적 원조를 요구한다.","t":"society"},{"w":"humility","p":"/hjuːˈmɪləti/","ps":"noun","me":"a modest view of one's importance","mk":"겸손","ex":"Humility is an admirable quality.","et":"겸손은 존경할 만한 자질이다.","t":"daily_life"},{"w":"hyperbole","p":"/haɪˈpɜːrbəli/","ps":"noun","me":"exaggerated statements","mk":"과장법","ex":"The claim is pure hyperbole.","et":"그 주장은 순전한 과장법이다.","t":"education"},{"w":"implement","p":"/ˈɪmplɪment/","ps":"verb","me":"to put into effect","mk":"시행하다","ex":"The school implemented new rules.","et":"학교는 새로운 규칙을 시행했다.","t":"education"},{"w":"implore","p":"/ɪmˈplɔːr/","ps":"verb","me":"to beg earnestly","mk":"간청하다","ex":"She implored them to reconsider.","et":"그녀는 재고해 달라고 간청했다.","t":"daily_life"},{"w":"incite","p":"/ɪnˈsaɪt/","ps":"verb","me":"to encourage violent action","mk":"선동하다","ex":"The speech incited public unrest.","et":"그 연설은 대중 불안을 선동했다.","t":"society"},{"w":"indict","p":"/ɪnˈdaɪt/","ps":"verb","me":"to formally accuse","mk":"기소하다","ex":"He was indicted for fraud.","et":"그는 사기로 기소되었다.","t":"society"},{"w":"ingenious","p":"/ɪnˈdʒiːniəs/","ps":"adjective","me":"cleverly inventive","mk":"독창적인","ex":"She proposed an ingenious solution.","et":"그녀는 독창적인 해결책을 제안했다.","t":"technology"},{"w":"innovative","p":"/ˈɪnəveɪtɪv/","ps":"adjective","me":"introducing new ideas","mk":"혁신적인","ex":"The company is known for innovative design.","et":"그 회사는 혁신적인 디자인으로 유명하다.","t":"technology"},{"w":"inordinate","p":"/ɪnˈɔːrdɪnət/","ps":"adjective","me":"unusually or excessively large","mk":"과도한","ex":"They spent an inordinate amount of time.","et":"그들은 과도한 시간을 소비했다.","t":"daily_life"},{"w":"insolvent","p":"/ɪnˈsɒlvənt/","ps":"adjective","me":"unable to pay debts","mk":"파산한","ex":"The firm became insolvent.","et":"그 회사는 파산했다.","t":"business"},{"w":"instantaneous","p":"/ˌɪnstənˈteɪniəs/","ps":"adjective","me":"occurring immediately","mk":"즉각적인","ex":"Communication is now nearly instantaneous.","et":"의사소통은 이제 거의 즉각적이다.","t":"technology"},{"w":"insular","p":"/ˈɪnsjʊlər/","ps":"adjective","me":"ignorant of other cultures","mk":"편협한","ex":"An insular mindset limits growth.","et":"편협한 사고방식은 성장을 제한한다.","t":"culture"},{"w":"integrate","p":"/ˈɪntɪɡreɪt/","ps":"verb","me":"to combine into a whole","mk":"통합하다","ex":"Schools must integrate technology.","et":"학교는 기술을 통합해야 한다.","t":"technology"},{"w":"interplay","p":"/ˈɪntərpleɪ/","ps":"noun","me":"the way things interact","mk":"상호작용","ex":"The interplay of culture and law.","et":"문화와 법의 상호작용.","t":"society"},{"w":"interrogate","p":"/ɪnˈterəɡeɪt/","ps":"verb","me":"to question closely","mk":"심문하다","ex":"Police interrogated the suspect.","et":"경찰은 용의자를 심문했다.","t":"society"},{"w":"intervene","p":"/ˌɪntərˈviːn/","ps":"verb","me":"to come between to alter events","mk":"개입하다","ex":"The government intervened in the crisis.","et":"정부가 위기에 개입했다.","t":"society"},{"w":"intimidate","p":"/ɪnˈtɪmɪdeɪt/","ps":"verb","me":"to frighten or overawe","mk":"위협하다","ex":"Bullies intimidate vulnerable students.","et":"괴롭히는 사람들이 취약한 학생을 위협한다.","t":"society"},{"w":"intriguing","p":"/ɪnˈtriːɡɪŋ/","ps":"adjective","me":"arousing curiosity","mk":"흥미로운","ex":"The findings are intriguing.","et":"그 발견은 흥미롭다.","t":"science"},{"w":"lethal","p":"/ˈliːθl/","ps":"adjective","me":"sufficient to cause death","mk":"치명적인","ex":"The dose can be lethal.","et":"그 용량은 치명적일 수 있다.","t":"health"},{"w":"liberal","p":"/ˈlɪbərəl/","ps":"adjective","me":"open to new ideas","mk":"자유주의적인","ex":"She holds liberal political views.","et":"그녀는 자유주의적 정치관을 가지고 있다.","t":"society"},{"w":"litigate","p":"/ˈlɪtɪɡeɪt/","ps":"verb","me":"to take legal action","mk":"소송하다","ex":"They chose to litigate the case.","et":"그들은 사건을 소송하기로 했다.","t":"society"},{"w":"magnify","p":"/ˈmæɡnɪfaɪ/","ps":"verb","me":"to make something appear larger","mk":"확대하다","ex":"The lens magnifies the image.","et":"렌즈가 이미지를 확대한다.","t":"science"},{"w":"menial","p":"/ˈmiːniəl/","ps":"adjective","me":"not requiring skill","mk":"하찮은","ex":"He resented doing menial tasks.","et":"그는 하찮은 일을 하는 것이 싫었다.","t":"business"},{"w":"minimize","p":"/ˈmɪnɪmaɪz/","ps":"verb","me":"to reduce to the smallest amount","mk":"최소화하다","ex":"We should minimize waste.","et":"우리는 낭비를 최소화해야 한다.","t":"environment"},{"w":"misconception","p":"/ˌmɪskənˈsepʃn/","ps":"noun","me":"a wrong belief","mk":"오해","ex":"That is a common misconception.","et":"그것은 흔한 오해이다.","t":"education"},{"w":"mobilize","p":"/ˈmoʊbɪlaɪz/","ps":"verb","me":"to organize for action","mk":"동원하다","ex":"They mobilized community support.","et":"그들은 지역사회 지원을 동원했다.","t":"society"},{"w":"modify","p":"/ˈmɒdɪfaɪ/","ps":"verb","me":"to make partial changes to","mk":"수정하다","ex":"The plan was modified slightly.","et":"계획이 약간 수정되었다.","t":"education"},{"w":"monopoly","p":"/məˈnɒpəli/","ps":"noun","me":"exclusive control of a supply","mk":"독점","ex":"The company holds a monopoly.","et":"그 회사는 독점을 보유하고 있다.","t":"business"},{"w":"navigate","p":"/ˈnævɪɡeɪt/","ps":"verb","me":"to find a way through","mk":"탐색하다","ex":"She navigated the complex system.","et":"그녀는 복잡한 시스템을 탐색했다.","t":"technology"},{"w":"nominate","p":"/ˈnɒmɪneɪt/","ps":"verb","me":"to propose for a position","mk":"지명하다","ex":"She was nominated for the award.","et":"그녀는 상 후보로 지명되었다.","t":"society"},{"w":"norm","p":"/nɔːrm/","ps":"noun","me":"a standard or pattern","mk":"규범","ex":"Cultural norms vary between countries.","et":"문화적 규범은 국가마다 다르다.","t":"culture"},{"w":"notable","p":"/ˈnoʊtəbl/","ps":"adjective","me":"worthy of attention","mk":"주목할 만한","ex":"There was a notable improvement.","et":"주목할 만한 개선이 있었다.","t":"education"},{"w":"notify","p":"/ˈnoʊtɪfaɪ/","ps":"verb","me":"to formally inform","mk":"통지하다","ex":"Please notify us in advance.","et":"사전에 통지해 주세요.","t":"business"},{"w":"novice","p":"/ˈnɒvɪs/","ps":"noun","me":"a person new to something","mk":"초보자","ex":"She is still a novice at coding.","et":"그녀는 아직 코딩 초보자이다.","t":"technology"},{"w":"obligatory","p":"/əˈblɪɡətɔːri/","ps":"adjective","me":"required by law or rule","mk":"의무적인","ex":"Attendance is obligatory.","et":"출석은 의무적이다.","t":"education"},{"w":"obstruct","p":"/əbˈstrʌkt/","ps":"verb","me":"to block or hinder","mk":"방해하다","ex":"Fallen trees obstructed the road.","et":"쓰러진 나무들이 도로를 방해했다.","t":"daily_life"},{"w":"offset","p":"/ˈɒfset/","ps":"verb","me":"to counterbalance","mk":"상쇄하다","ex":"Gains offset the earlier losses.","et":"이익이 이전 손실을 상쇄했다.","t":"business"},{"w":"ongoing","p":"/ˈɒnɡoʊɪŋ/","ps":"adjective","me":"continuing without interruption","mk":"진행 중인","ex":"Research is ongoing.","et":"연구가 진행 중이다.","t":"science"},{"w":"onset","p":"/ˈɒnset/","ps":"noun","me":"the beginning of something","mk":"시작","ex":"The onset of symptoms was sudden.","et":"증상의 시작은 갑작스러웠다.","t":"health"},{"w":"opt","p":"/ɒpt/","ps":"verb","me":"to make a choice","mk":"선택하다","ex":"Many students opt for online classes.","et":"많은 학생들이 온라인 수업을 선택한다.","t":"education"},{"w":"oust","p":"/aʊst/","ps":"verb","me":"to drive out or expel","mk":"축출하다","ex":"The CEO was ousted by the board.","et":"CEO는 이사회에 의해 축출되었다.","t":"business"},{"w":"outweigh","p":"/ˌaʊtˈweɪ/","ps":"verb","me":"to be greater in importance","mk":"~보다 중요하다","ex":"The benefits outweigh the risks.","et":"이점이 위험보다 중요하다.","t":"daily_life"},{"w":"oversee","p":"/ˌoʊvərˈsiː/","ps":"verb","me":"to supervise","mk":"감독하다","ex":"She oversees the entire department.","et":"그녀는 전체 부서를 감독한다.","t":"business"},{"w":"overwhelm","p":"/ˌoʊvərˈwelm/","ps":"verb","me":"to overpower with emotion or force","mk":"압도하다","ex":"The response overwhelmed organizers.","et":"반응이 주최 측을 압도했다.","t":"daily_life"},{"w":"partake","p":"/pɑːrˈteɪk/","ps":"verb","me":"to join in an activity","mk":"참여하다","ex":"Everyone can partake in the event.","et":"모두가 행사에 참여할 수 있다.","t":"culture"},{"w":"penetrate","p":"/ˈpenɪtreɪt/","ps":"verb","me":"to succeed in entering","mk":"침투하다","ex":"The company penetrated new markets.","et":"회사는 새로운 시장에 침투했다.","t":"business"},{"w":"persist","p":"/pərˈsɪst/","ps":"verb","me":"to continue firmly","mk":"지속하다","ex":"Problems persist despite efforts.","et":"노력에도 불구하고 문제가 지속된다.","t":"daily_life"},{"w":"predecessor","p":"/ˈpriːdəsesər/","ps":"noun","me":"a person who held a position before","mk":"전임자","ex":"His predecessor was very effective.","et":"그의 전임자는 매우 효과적이었다.","t":"business"},{"w":"preliminary","p":"/prɪˈlɪmɪnəri/","ps":"adjective","me":"coming before the main event","mk":"예비의","ex":"Preliminary results are promising.","et":"예비 결과가 유망하다.","t":"science"},{"w":"prerequisite","p":"/priːˈrekwɪzɪt/","ps":"noun","me":"something required beforehand","mk":"전제 조건","ex":"Experience is a prerequisite.","et":"경험이 전제 조건이다.","t":"education"},{"w":"prescribe","p":"/prɪˈskraɪb/","ps":"verb","me":"to recommend with authority","mk":"처방하다","ex":"The doctor prescribed rest.","et":"의사가 휴식을 처방했다.","t":"health"},{"w":"prestige","p":"/preˈstiːʒ/","ps":"noun","me":"widespread respect and admiration","mk":"명성","ex":"The university has great prestige.","et":"그 대학은 큰 명성을 가지고 있다.","t":"education"},{"w":"presume","p":"/prɪˈzjuːm/","ps":"verb","me":"to suppose something is true","mk":"추정하다","ex":"We presume he is innocent.","et":"우리는 그가 무죄라고 추정한다.","t":"society"},{"w":"prevail","p":"/prɪˈveɪl/","ps":"verb","me":"to prove more powerful","mk":"우세하다","ex":"Justice will ultimately prevail.","et":"정의가 궁극적으로 우세할 것이다.","t":"society"},{"w":"prohibit","p":"/prəˈhɪbɪt/","ps":"verb","me":"to formally forbid by law","mk":"금지하다","ex":"The law prohibits discrimination.","et":"법은 차별을 금지한다.","t":"society"},{"w":"prompt","p":"/prɒmpt/","ps":"verb","me":"to cause something to happen","mk":"촉발하다","ex":"The crisis prompted reforms.","et":"위기가 개혁을 촉발했다.","t":"society"},{"w":"prone","p":"/proʊn/","ps":"adjective","me":"likely to do something","mk":"~하기 쉬운","ex":"Children are prone to infections.","et":"아이들은 감염에 걸리기 쉽다.","t":"health"},{"w":"proportion","p":"/prəˈpɔːrʃn/","ps":"noun","me":"a part in relation to the whole","mk":"비율","ex":"A large proportion voted yes.","et":"큰 비율이 찬성 투표했다.","t":"society"},{"w":"prosecute","p":"/ˈprɒsɪkjuːt/","ps":"verb","me":"to institute legal proceedings","mk":"기소하다","ex":"They will prosecute offenders.","et":"그들은 범죄자를 기소할 것이다.","t":"society"},{"w":"prospective","p":"/prəˈspektɪv/","ps":"adjective","me":"expected or likely to happen","mk":"장래의","ex":"Prospective students must apply early.","et":"장래의 학생들은 일찍 지원해야 한다.","t":"education"},{"w":"protocol","p":"/ˈproʊtəkɒl/","ps":"noun","me":"a system of rules","mk":"프로토콜","ex":"Follow the safety protocol.","et":"안전 프로토콜을 따르라.","t":"science"},{"w":"radical","p":"/ˈrædɪkl/","ps":"adjective","me":"relating to fundamental change","mk":"급진적인","ex":"The proposal is quite radical.","et":"그 제안은 꽤 급진적이다.","t":"society"},{"w":"reap","p":"/riːp/","ps":"verb","me":"to receive as a result","mk":"거두다","ex":"They reaped the benefits of hard work.","et":"그들은 노력의 혜택을 거두었다.","t":"daily_life"},{"w":"refine","p":"/rɪˈfaɪn/","ps":"verb","me":"to improve by making small changes","mk":"정제하다","ex":"They refined the methodology.","et":"그들은 방법론을 정제했다.","t":"science"},{"w":"reform","p":"/rɪˈfɔːrm/","ps":"noun","me":"improvement by change","mk":"개혁","ex":"Education reform is essential.","et":"교육 개혁은 필수적이다.","t":"education"},{"w":"regime","p":"/reɪˈʒiːm/","ps":"noun","me":"a system of government","mk":"정권","ex":"The regime oppressed its citizens.","et":"정권은 시민을 억압했다.","t":"society"},{"w":"regulate","p":"/ˈreɡjʊleɪt/","ps":"verb","me":"to control by rules","mk":"규제하다","ex":"The industry is heavily regulated.","et":"그 산업은 강하게 규제된다.","t":"business"},{"w":"reinforce","p":"/ˌriːɪnˈfɔːrs/","ps":"verb","me":"to strengthen","mk":"강화하다","ex":"Practice reinforces learning.","et":"연습이 학습을 강화한다.","t":"education"},{"w":"reluctant","p":"/rɪˈlʌktənt/","ps":"adjective","me":"unwilling to do something","mk":"꺼리는","ex":"He was reluctant to accept.","et":"그는 수락하기를 꺼렸다.","t":"daily_life"},{"w":"remedy","p":"/ˈremədi/","ps":"noun","me":"a medicine or solution","mk":"치료법","ex":"There is no simple remedy.","et":"간단한 치료법은 없다.","t":"health"},{"w":"resolve","p":"/rɪˈzɒlv/","ps":"verb","me":"to settle or find a solution","mk":"해결하다","ex":"We must resolve this conflict.","et":"우리는 이 갈등을 해결해야 한다.","t":"society"},{"w":"retrieve","p":"/rɪˈtriːv/","ps":"verb","me":"to get something back","mk":"되찾다, 회수하다","ex":"The system can retrieve old files.","et":"시스템은 오래된 파일을 검색할 수 있다.","t":"technology"},{"w":"revelation","p":"/ˌrevəˈleɪʃn/","ps":"noun","me":"a surprising disclosure","mk":"폭로","ex":"The revelation shocked the public.","et":"그 폭로는 대중에게 충격을 주었다.","t":"society"},{"w":"revenue","p":"/ˈrevənjuː/","ps":"noun","me":"income from business activities","mk":"수익","ex":"Revenue increased by ten percent.","et":"수익이 10퍼센트 증가했다.","t":"business"},{"w":"scarcity","p":"/ˈskeərsəti/","ps":"noun","me":"the state of being in short supply","mk":"부족","ex":"Water scarcity is a global issue.","et":"물 부족은 세계적인 문제이다.","t":"environment"},{"w":"scrutinize","p":"/ˈskruːtɪnaɪz/","ps":"verb","me":"to examine closely","mk":"면밀히 조사하다","ex":"Regulators scrutinized the company.","et":"규제 기관이 회사를 면밀히 조사했다.","t":"business"},{"w":"segregate","p":"/ˈseɡrɪɡeɪt/","ps":"verb","me":"to separate from the rest","mk":"분리하다","ex":"Waste should be segregated.","et":"폐기물은 분리되어야 한다.","t":"environment"},{"w":"simultaneously","p":"/ˌsaɪmlˈteɪniəsli/","ps":"adverb","me":"at the same time","mk":"동시에","ex":"Both events occurred simultaneously.","et":"두 사건이 동시에 발생했다.","t":"daily_life"},{"w":"solitary","p":"/ˈsɒlɪtəri/","ps":"adjective","me":"done or existing alone","mk":"고독한","ex":"He leads a solitary life.","et":"그는 고독한 삶을 산다.","t":"daily_life"},{"w":"stem","p":"/stem/","ps":"verb","me":"to originate from","mk":"~에서 비롯되다","ex":"Problems stem from poor planning.","et":"문제는 부실한 계획에서 비롯된다.","t":"daily_life"},{"w":"stimulate","p":"/ˈstɪmjʊleɪt/","ps":"verb","me":"to encourage development","mk":"자극하다","ex":"Exercise stimulates brain activity.","et":"운동은 뇌 활동을 자극한다.","t":"health"},{"w":"substitute","p":"/ˈsʌbstɪtjuːt/","ps":"noun","me":"a person or thing acting in place","mk":"대체물","ex":"There is no substitute for experience.","et":"경험을 대체할 수 있는 것은 없다.","t":"daily_life"},{"w":"subtle","p":"/ˈsʌtl/","ps":"adjective","me":"so delicate as to be hard to notice","mk":"미묘한","ex":"There was a subtle difference.","et":"미묘한 차이가 있었다.","t":"daily_life"},{"w":"successive","p":"/səkˈsesɪv/","ps":"adjective","me":"following one after another","mk":"연속적인","ex":"It rained for three successive days.","et":"3일 연속으로 비가 내렸다.","t":"daily_life"},{"w":"surge","p":"/sɜːrdʒ/","ps":"noun","me":"a sudden powerful forward movement","mk":"급증","ex":"There was a surge in demand.","et":"수요 급증이 있었다.","t":"business"},{"w":"surplus","p":"/ˈsɜːrpləs/","ps":"noun","me":"an amount greater than needed","mk":"잉여","ex":"The country has a trade surplus.","et":"그 나라는 무역 잉여가 있다.","t":"business"},{"w":"surveillance","p":"/sɜːrˈveɪləns/","ps":"noun","me":"close observation","mk":"감시","ex":"Surveillance cameras are widespread.","et":"감시 카메라가 널리 퍼져 있다.","t":"technology"},{"w":"suspend","p":"/səˈspend/","ps":"verb","me":"to temporarily stop","mk":"중단하다","ex":"Operations were suspended immediately.","et":"운영이 즉시 중단되었다.","t":"business"},{"w":"terminate","p":"/ˈtɜːrmɪneɪt/","ps":"verb","me":"to bring to an end","mk":"종료하다","ex":"The contract was terminated.","et":"계약이 종료되었다.","t":"business"},{"w":"tout","p":"/taʊt/","ps":"verb","me":"to promote or advertise","mk":"선전하다","ex":"The company touted its new product.","et":"회사는 신제품을 선전했다.","t":"business"},{"w":"acclaimed","p":"/əˈkleɪmd/","ps":"adjective","me":"publicly praised","mk":"호평받는","ex":"The acclaimed film won awards.","et":"호평받는 영화가 상을 받았다.","t":"culture"},{"w":"acquaint","p":"/əˈkweɪnt/","ps":"verb","me":"make familiar with","mk":"익숙하게 하다","ex":"Please acquaint yourself with rules.","et":"규칙을 숙지해 주세요.","t":"education"},{"w":"adamant","p":"/ˈædəmənt/","ps":"adjective","me":"firmly determined","mk":"단호한","ex":"She was adamant about her decision.","et":"그녀는 결정에 단호했다.","t":"daily_life"},{"w":"adjourn","p":"/əˈdʒɜːrn/","ps":"verb","me":"suspend a meeting","mk":"휴회하다","ex":"The court adjourned until Monday.","et":"법원은 월요일까지 휴회했다.","t":"society"},{"w":"aggravation","p":"/ˌæɡrəˈveɪʃən/","ps":"noun","me":"worsening of a situation","mk":"악화","ex":"Pollution caused aggravation of asthma.","et":"오염이 천식 악화를 초래했다.","t":"health"},{"w":"agile","p":"/ˈædʒaɪl/","ps":"adjective","me":"quick and flexible","mk":"민첩한","ex":"Agile teams adapt to change fast.","et":"민첩한 팀은 변화에 빨리 적응한다.","t":"business"},{"w":"albeit","p":"/ɔːlˈbiːɪt/","ps":"conjunction","me":"although","mk":"비록~이지만","ex":"He agreed, albeit with reservations.","et":"그는 비록 유보적이지만 동의했다.","t":"daily_life"},{"w":"alienate","p":"/ˈeɪliəneɪt/","ps":"verb","me":"cause to feel isolated","mk":"소외시키다","ex":"Strict policies alienate young workers.","et":"엄격한 정책이 젊은 직원을 소외시킨다.","t":"society"},{"w":"allegation","p":"/ˌæləˈɡeɪʃən/","ps":"noun","me":"unproven accusation","mk":"혐의, 의혹","ex":"The allegation was never proven.","et":"그 주장은 증명되지 않았다.","t":"society"},{"w":"amenity","p":"/əˈmiːnəti/","ps":"noun","me":"useful facility or feature","mk":"편의시설","ex":"The hotel offers many amenities.","et":"호텔은 많은 편의시설을 제공한다.","t":"travel"},{"w":"anecdote","p":"/ˈænɪkdoʊt/","ps":"noun","me":"short amusing story","mk":"일화","ex":"He shared an amusing anecdote.","et":"그는 재미있는 일화를 나누었다.","t":"culture"},{"w":"apparatus","p":"/ˌæpəˈrætəs/","ps":"noun","me":"equipment for a task","mk":"장치","ex":"The lab apparatus was calibrated.","et":"실험실 장치가 보정되었다.","t":"science"},{"w":"articulation","p":"/ɑːrˌtɪkjʊˈleɪʃən/","ps":"noun","me":"clear expression of ideas","mk":"명확한 표현","ex":"Clear articulation is vital in debates.","et":"명확한 표현은 토론에서 중요하다.","t":"education"},{"w":"aspire","p":"/əˈspaɪər/","ps":"verb","me":"aim for something great","mk":"열망하다","ex":"She aspires to become a surgeon.","et":"그녀는 외과의사가 되기를 열망한다.","t":"education"},{"w":"avid","p":"/ˈævɪd/","ps":"adjective","me":"enthusiastic and eager","mk":"열렬한","ex":"She is an avid book reader.","et":"그녀는 열렬한 독서가이다.","t":"culture"},{"w":"botany","p":"/ˈbɒtəni/","ps":"noun","me":"study of plants","mk":"식물학","ex":"She studied botany at university.","et":"그녀는 대학에서 식물학을 공부했다.","t":"science"},{"w":"bottleneck","p":"/ˈbɒtlnɛk/","ps":"noun","me":"point of congestion","mk":"병목","ex":"Traffic bottleneck delays commuters daily.","et":"교통 병목이 매일 통근자를 지연시킨다.","t":"daily_life"},{"w":"capitalize","p":"/ˈkæpɪtəlaɪz/","ps":"verb","me":"take advantage of","mk":"활용하다","ex":"Firms capitalize on market trends.","et":"기업은 시장 동향을 활용한다.","t":"business"},{"w":"cascade","p":"/kæˈskeɪd/","ps":"noun","me":"a series of events","mk":"연쇄","ex":"A cascade of errors caused failure.","et":"오류의 연쇄가 실패를 초래했다.","t":"science"},{"w":"caveat","p":"/ˈkæviæt/","ps":"noun","me":"warning or condition","mk":"경고","ex":"One caveat applies to this study.","et":"하나의 경고가 이 연구에 적용된다.","t":"science"},{"w":"chronological","p":"/ˌkrɒnəˈlɒdʒɪkəl/","ps":"adjective","me":"in time order","mk":"연대순의","ex":"Events are listed in chronological order.","et":"사건이 연대순으로 나열되어 있다.","t":"education"},{"w":"civic","p":"/ˈsɪvɪk/","ps":"adjective","me":"relating to citizens","mk":"시민의","ex":"Civic participation strengthens democracy.","et":"시민 참여가 민주주의를 강화한다.","t":"society"},{"w":"cognitive","p":"/ˈkɒɡnɪtɪv/","ps":"adjective","me":"relating to mental processes","mk":"인지의","ex":"Cognitive skills develop in childhood.","et":"인지 능력은 어린 시절에 발달한다.","t":"health"},{"w":"combustion","p":"/kəmˈbʌstʃən/","ps":"noun","me":"process of burning","mk":"연소","ex":"Combustion releases carbon dioxide gas.","et":"연소가 이산화탄소를 방출한다.","t":"science"},{"w":"commemorative","p":"/kəˈmɛmərətɪv/","ps":"adjective","me":"honoring a memory","mk":"기념의","ex":"A commemorative stamp was issued.","et":"기념 우표가 발행되었다.","t":"culture"},{"w":"competence","p":"/ˈkɒmpɪtəns/","ps":"noun","me":"ability to do well","mk":"능력","ex":"Technical competence is highly valued.","et":"기술적 능력은 높이 평가된다.","t":"business"},{"w":"compliance","p":"/kəmˈplaɪəns/","ps":"noun","me":"obeying rules or standards","mk":"준수","ex":"Compliance with regulations is mandatory.","et":"규정 준수는 의무적이다.","t":"business"},{"w":"comprised","p":"/kəmˈpraɪzd/","ps":"adjective","me":"made up of","mk":"구성된","ex":"The team is comprised of experts.","et":"팀은 전문가로 구성되어 있다.","t":"business"},{"w":"confront","p":"/kənˈfrʌnt/","ps":"verb","me":"face a challenge directly","mk":"직면하다","ex":"We must confront climate change now.","et":"우리는 지금 기후 변화에 직면해야 한다.","t":"environment"},{"w":"constituent","p":"/kənˈstɪtjuənt/","ps":"noun","me":"component part or voter","mk":"구성 요소","ex":"Water is a constituent of blood.","et":"물은 혈액의 구성 요소이다.","t":"science"},{"w":"contingency","p":"/kənˈtɪndʒənsi/","ps":"noun","me":"possible future event","mk":"비상사태","ex":"We need a contingency plan ready.","et":"비상 계획을 준비해야 한다.","t":"business"},{"w":"convergence","p":"/kənˈvɜːrdʒəns/","ps":"noun","me":"coming together","mk":"수렴","ex":"A convergence of ideas emerged.","et":"아이디어의 수렴이 나타났다.","t":"science"},{"w":"counterpart","p":"/ˈkaʊntərpɑːrt/","ps":"noun","me":"equivalent person or thing","mk":"상대","ex":"She met her foreign counterpart.","et":"그녀는 외국 상대를 만났다.","t":"business"},{"w":"credibility","p":"/ˌkrɛdɪˈbɪləti/","ps":"noun","me":"quality of being trusted","mk":"신뢰성","ex":"His credibility was seriously damaged.","et":"그의 신뢰성이 심각하게 손상되었다.","t":"society"},{"w":"customary","p":"/ˈkʌstəməri/","ps":"adjective","me":"usual or traditional","mk":"관례적인","ex":"It is customary to tip servers.","et":"서버에게 팁을 주는 것이 관례적이다.","t":"culture"},{"w":"decentralize","p":"/diːˈsɛntrəlaɪz/","ps":"verb","me":"distribute authority widely","mk":"분산시키다","ex":"The government plans to decentralize power.","et":"정부는 권력을 분산시킬 계획이다.","t":"society"},{"w":"decipher","p":"/dɪˈsaɪfər/","ps":"verb","me":"decode or interpret","mk":"해독하다","ex":"Scientists deciphered the ancient text.","et":"과학자들이 고대 문서를 해독했다.","t":"science"},{"w":"degradation","p":"/ˌdɛɡrəˈdeɪʃən/","ps":"noun","me":"decline in quality","mk":"저하","ex":"Soil degradation threatens food supply.","et":"토양 저하가 식량 공급을 위협한다.","t":"environment"},{"w":"detain","p":"/dɪˈteɪn/","ps":"verb","me":"keep in custody","mk":"구금하다","ex":"Police detained the suspect briefly.","et":"경찰이 용의자를 잠시 구금했다.","t":"society"},{"w":"deteriorate","p":"/dɪˈtɪəriəreɪt/","ps":"verb","me":"become progressively worse","mk":"악화되다","ex":"Air quality continues to deteriorate.","et":"대기 질이 계속 악화되고 있다.","t":"environment"},{"w":"diagnose","p":"/ˈdaɪəɡnoʊz/","ps":"verb","me":"identify a disease","mk":"진단하다","ex":"Doctors diagnosed the rare condition.","et":"의사들이 희귀 질환을 진단했다.","t":"health"},{"w":"durable","p":"/ˈdjʊərəbəl/","ps":"adjective","me":"long-lasting and sturdy","mk":"내구성 있는","ex":"Choose durable materials for construction.","et":"건설에 내구성 있는 재료를 선택하라.","t":"technology"},{"w":"dynamic","p":"/daɪˈnæmɪk/","ps":"adjective","me":"constantly changing and active","mk":"역동적인","ex":"The market is highly dynamic.","et":"시장이 매우 역동적이다.","t":"business"},{"w":"dysfunction","p":"/dɪsˈfʌŋkʃən/","ps":"noun","me":"abnormal or impaired function","mk":"기능 장애","ex":"Organ dysfunction requires immediate treatment.","et":"장기 기능 장애는 즉각적인 치료가 필요하다.","t":"health"},{"w":"edifice","p":"/ˈɛdɪfɪs/","ps":"noun","me":"large impressive building","mk":"건축물","ex":"The ancient edifice still stands.","et":"고대 건축물이 여전히 서 있다.","t":"culture"},{"w":"elapse","p":"/ɪˈlæps/","ps":"verb","me":"pass or go by","mk":"경과하다","ex":"Several months elapsed before a reply.","et":"답변까지 몇 달이 경과했다.","t":"daily_life"},{"w":"essence","p":"/ˈɛsəns/","ps":"noun","me":"fundamental nature","mk":"본질","ex":"Speed is the essence of success.","et":"속도가 성공의 본질이다.","t":"business"},{"w":"exempt","p":"/ɪɡˈzɛmpt/","ps":"adjective","me":"free from obligation","mk":"면제된","ex":"Students are exempt from the fee.","et":"학생들은 요금이 면제된다.","t":"education"},{"w":"exhaust","p":"/ɪɡˈzɔːst/","ps":"verb","me":"use up completely","mk":"소진하다","ex":"We may exhaust natural resources.","et":"천연자원을 소진할 수 있다.","t":"environment"},{"w":"exhibit","p":"/ɪɡˈzɪbɪt/","ps":"verb","me":"display or show","mk":"전시하다","ex":"The gallery exhibits modern art.","et":"갤러리가 현대 미술을 전시한다.","t":"culture"},{"w":"exquisite","p":"/ɪkˈskwɪzɪt/","ps":"adjective","me":"extremely beautiful","mk":"정교한","ex":"The exquisite craftsmanship impressed visitors.","et":"정교한 장인 정신이 방문객을 감동시켰다.","t":"culture"},{"w":"facade","p":"/fəˈsɑːd/","ps":"noun","me":"front of a building or pretense","mk":"외관","ex":"The facade hides structural problems.","et":"외관이 구조적 문제를 숨긴다.","t":"culture"},{"w":"flagship","p":"/ˈflæɡʃɪp/","ps":"noun","me":"leading product or brand","mk":"주력","ex":"This is the company's flagship product.","et":"이것이 회사의 주력 제품이다.","t":"business"},{"w":"fragmented","p":"/ˈfræɡmɛntɪd/","ps":"adjective","me":"broken into parts","mk":"단편화된","ex":"The market is highly fragmented.","et":"시장이 매우 단편화되어 있다.","t":"business"},{"w":"gauge","p":"/ɡeɪdʒ/","ps":"verb","me":"estimate or measure","mk":"측정하다","ex":"Surveys gauge public opinion effectively.","et":"설문조사가 여론을 효과적으로 측정한다.","t":"society"},{"w":"genome","p":"/ˈdʒiːnoʊm/","ps":"noun","me":"complete set of genes","mk":"게놈","ex":"The human genome was fully mapped.","et":"인간 게놈이 완전히 매핑되었다.","t":"science"},{"w":"harmonize","p":"/ˈhɑːrmənaɪz/","ps":"verb","me":"bring into agreement","mk":"조화시키다","ex":"We must harmonize trade regulations.","et":"무역 규정을 조화시켜야 한다.","t":"business"},{"w":"hereditary","p":"/hɪˈrɛdɪtəri/","ps":"adjective","me":"passed through genes","mk":"유전적인","ex":"The condition is hereditary in nature.","et":"이 질환은 유전적 성격이다.","t":"health"},{"w":"immunity","p":"/ɪˈmjuːnəti/","ps":"noun","me":"resistance to disease","mk":"면역","ex":"Vaccines build immunity against viruses.","et":"백신이 바이러스에 대한 면역을 형성한다.","t":"health"},{"w":"incidence","p":"/ˈɪnsɪdəns/","ps":"noun","me":"rate of occurrence","mk":"발생률","ex":"The incidence of diabetes is rising.","et":"당뇨병 발생률이 증가하고 있다.","t":"health"},{"w":"integrity","p":"/ɪnˈtɛɡrəti/","ps":"noun","me":"moral uprightness","mk":"진실성","ex":"She is known for her integrity.","et":"그녀는 진실성으로 알려져 있다.","t":"daily_life"},{"w":"itinerary","p":"/aɪˈtɪnərəri/","ps":"noun","me":"planned route or journey","mk":"여행 일정","ex":"Check your itinerary before traveling.","et":"여행 전에 여행 일정을 확인하라.","t":"travel"},{"w":"kinship","p":"/ˈkɪnʃɪp/","ps":"noun","me":"family relationship or bond","mk":"유대","ex":"Kinship ties remain strong in rural areas.","et":"시골 지역에서 유대 관계가 강하다.","t":"culture"},{"w":"laborious","p":"/ləˈbɔːriəs/","ps":"adjective","me":"requiring much effort","mk":"힘든","ex":"Data entry is a laborious task.","et":"데이터 입력은 힘든 작업이다.","t":"business"},{"w":"landmark","p":"/ˈlændmɑːrk/","ps":"noun","me":"important event or place","mk":"획기적 사건","ex":"The ruling was a legal landmark.","et":"판결은 법적 획기적 사건이었다.","t":"society"},{"w":"liability","p":"/ˌlaɪəˈbɪləti/","ps":"noun","me":"legal responsibility or debt","mk":"책임","ex":"The company denied all liability.","et":"회사가 모든 책임을 부인했다.","t":"business"},{"w":"literacy","p":"/ˈlɪtərəsi/","ps":"noun","me":"ability to read and write","mk":"문해력","ex":"Digital literacy is essential today.","et":"디지털 문해력이 오늘날 필수적이다.","t":"education"},{"w":"logistics","p":"/ləˈdʒɪstɪks/","ps":"noun","me":"detailed coordination","mk":"물류","ex":"Supply chain logistics are complex.","et":"공급망 물류가 복잡하다.","t":"business"},{"w":"magnitude","p":"/ˈmæɡnɪtjuːd/","ps":"noun","me":"great size or importance","mk":"규모","ex":"The magnitude of the problem grew.","et":"문제의 규모가 커졌다.","t":"science"},{"w":"malfunction","p":"/mælˈfʌŋkʃən/","ps":"noun","me":"failure to operate correctly","mk":"오작동","ex":"A malfunction caused the system crash.","et":"오작동이 시스템 충돌을 초래했다.","t":"technology"},{"w":"maternal","p":"/məˈtɜːrnəl/","ps":"adjective","me":"relating to a mother","mk":"모성의","ex":"Maternal health is a global priority.","et":"모성 건강은 세계적 우선과제이다.","t":"health"},{"w":"menace","p":"/ˈmɛnəs/","ps":"noun","me":"something threatening","mk":"위협","ex":"Pollution is a menace to health.","et":"오염은 건강에 위협이다.","t":"environment"},{"w":"mentor","p":"/ˈmɛntɔːr/","ps":"noun","me":"experienced guide or advisor","mk":"멘토","ex":"Every student needs a good mentor.","et":"모든 학생에게 좋은 멘토가 필요하다.","t":"education"},{"w":"metropolis","p":"/mɪˈtrɒpəlɪs/","ps":"noun","me":"large important city","mk":"대도시","ex":"Tokyo is a bustling metropolis.","et":"도쿄는 번화한 대도시이다.","t":"travel"},{"w":"militant","p":"/ˈmɪlɪtənt/","ps":"adjective","me":"aggressively active","mk":"전투적인","ex":"Militant groups oppose the policy.","et":"전투적인 단체가 정책에 반대한다.","t":"society"},{"w":"monarchy","p":"/ˈmɒnərki/","ps":"noun","me":"rule by a king or queen","mk":"군주제","ex":"The monarchy has symbolic power.","et":"군주제가 상징적 권력을 가지고 있다.","t":"society"},{"w":"monetary","p":"/ˈmʌnɪtəri/","ps":"adjective","me":"relating to money","mk":"금전적인","ex":"Monetary policy controls inflation rates.","et":"통화 정책이 인플레이션을 통제한다.","t":"business"},{"w":"mortality","p":"/mɔːrˈtæləti/","ps":"noun","me":"death rate","mk":"사망률","ex":"Child mortality has decreased globally.","et":"아동 사망률이 전 세계적으로 감소했다.","t":"health"},{"w":"municipal","p":"/mjuːˈnɪsɪpəl/","ps":"adjective","me":"relating to a city","mk":"시의","ex":"Municipal services include waste collection.","et":"시 서비스에는 쓰레기 수거가 포함된다.","t":"society"},{"w":"nomadic","p":"/noʊˈmædɪk/","ps":"adjective","me":"living as a wanderer","mk":"유목민의","ex":"Nomadic tribes follow seasonal routes.","et":"유목민 부족이 계절 경로를 따른다.","t":"culture"},{"w":"obligation","p":"/ˌɒblɪˈɡeɪʃən/","ps":"noun","me":"duty or commitment","mk":"의무","ex":"Employers have a legal obligation.","et":"고용주에게 법적 의무가 있다.","t":"business"},{"w":"omit","p":"/oʊˈmɪt/","ps":"verb","me":"leave out or exclude","mk":"생략하다","ex":"Do not omit any important details.","et":"중요한 세부사항을 생략하지 마라.","t":"education"},{"w":"ostensibly","p":"/ɒˈstɛnsɪbli/","ps":"adverb","me":"apparently but not really","mk":"표면상으로","ex":"He left ostensibly for health reasons.","et":"그는 표면상으로 건강상의 이유로 떠났다.","t":"daily_life"},{"w":"oversight","p":"/ˈoʊvərsaɪt/","ps":"noun","me":"supervision or unintentional error","mk":"감독","ex":"Regulatory oversight prevents fraud.","et":"규제 감독이 사기를 방지한다.","t":"business"},{"w":"patronage","p":"/ˈpætrənɪdʒ/","ps":"noun","me":"support given by a patron","mk":"후원","ex":"The arts rely on public patronage.","et":"예술은 대중의 후원에 의존한다.","t":"culture"},{"w":"peer","p":"/pɪər/","ps":"noun","me":"person of equal standing","mk":"동료","ex":"Peer review ensures research quality.","et":"동료 검토가 연구 질을 보장한다.","t":"education"},{"w":"per capita","p":"/pɜːr ˈkæpɪtə/","ps":"adverb","me":"for each person","mk":"1인당","ex":"Income per capita has risen.","et":"1인당 소득이 증가했다.","t":"business"},{"w":"permeable","p":"/ˈpɜːrmiəbəl/","ps":"adjective","me":"allowing liquids to pass","mk":"투과성의","ex":"The soil is highly permeable.","et":"토양이 매우 투과성이 있다.","t":"science"},{"w":"pledge","p":"/plɛdʒ/","ps":"verb","me":"make a solemn promise","mk":"서약하다","ex":"Leaders pledged to reduce emissions.","et":"지도자들이 배출 감소를 서약했다.","t":"environment"},{"w":"proficiency","p":"/prəˈfɪʃənsi/","ps":"noun","me":"high skill level","mk":"숙련도","ex":"Language proficiency is required.","et":"언어 숙련도가 요구된다.","t":"education"},{"w":"prolong","p":"/prəˈlɒŋ/","ps":"verb","me":"extend the duration","mk":"연장하다","ex":"Exercise can prolong life expectancy.","et":"운동이 기대 수명을 연장할 수 있다.","t":"health"},{"w":"prominence","p":"/ˈprɒmɪnəns/","ps":"noun","me":"state of being important","mk":"저명함","ex":"She rose to prominence quickly.","et":"그녀는 빠르게 저명해졌다.","t":"society"},{"w":"proportional","p":"/prəˈpɔːrʃənəl/","ps":"adjective","me":"corresponding in size","mk":"비례하는","ex":"Tax should be proportional to income.","et":"세금은 소득에 비례해야 한다.","t":"business"},{"w":"proposition","p":"/ˌprɒpəˈzɪʃən/","ps":"noun","me":"statement or proposal","mk":"제안","ex":"The proposition was rejected by voters.","et":"제안이 유권자에 의해 거부되었다.","t":"society"},{"w":"recurrent","p":"/rɪˈkʌrənt/","ps":"adjective","me":"occurring repeatedly","mk":"반복되는","ex":"Recurrent flooding damages the village.","et":"반복되는 홍수가 마을을 손상시킨다.","t":"environment"},{"w":"rehabilitation","p":"/ˌriːəˌbɪlɪˈteɪʃən/","ps":"noun","me":"restoring to normal","mk":"재활","ex":"Rehabilitation after surgery takes months.","et":"수술 후 재활은 몇 달 걸린다.","t":"health"},{"w":"reimburse","p":"/ˌriːɪmˈbɜːrs/","ps":"verb","me":"repay money spent","mk":"상환하다","ex":"The company reimburses travel expenses.","et":"회사가 여행 경비를 상환한다.","t":"business"},{"w":"remit","p":"/rɪˈmɪt/","ps":"noun","me":"area of responsibility","mk":"소관","ex":"That falls outside our remit.","et":"그것은 우리 소관 밖이다.","t":"business"},{"w":"replicate","p":"/ˈrɛplɪkeɪt/","ps":"verb","me":"reproduce exactly","mk":"복제하다","ex":"Scientists replicated the experiment.","et":"과학자들이 실험을 복제했다.","t":"science"},{"w":"retrospective","p":"/ˌrɛtrəˈspɛktɪv/","ps":"adjective","me":"looking back at the past","mk":"회고적인","ex":"A retrospective analysis was conducted.","et":"회고적 분석이 수행되었다.","t":"science"},{"w":"revamp","p":"/riːˈvæmp/","ps":"verb","me":"renovate or improve","mk":"개선하다","ex":"The website was completely revamped.","et":"웹사이트가 완전히 개선되었다.","t":"technology"},{"w":"scenario","p":"/sɪˈnærioʊ/","ps":"noun","me":"possible sequence of events","mk":"시나리오","ex":"Consider the worst-case scenario.","et":"최악의 시나리오를 고려하라.","t":"business"},{"w":"segregation","p":"/ˌsɛɡrɪˈɡeɪʃən/","ps":"noun","me":"separation of groups","mk":"분리","ex":"Racial segregation was outlawed decades ago.","et":"인종 분리는 수십 년 전에 불법화되었다.","t":"society"},{"w":"speculative","p":"/ˈspɛkjʊlətɪv/","ps":"adjective","me":"based on conjecture","mk":"추측성의","ex":"The investment is highly speculative.","et":"투자가 매우 추측성이다.","t":"business"},{"w":"stakeholder","p":"/ˈsteɪkhoʊldər/","ps":"noun","me":"person with an interest","mk":"이해관계자","ex":"All stakeholders were consulted.","et":"모든 이해관계자가 협의되었다.","t":"business"},{"w":"stereotype","p":"/ˈstɛriətaɪp/","ps":"noun","me":"oversimplified fixed image","mk":"고정관념","ex":"We must challenge harmful stereotypes.","et":"해로운 고정관념에 도전해야 한다.","t":"society"},{"w":"syndrome","p":"/ˈsɪndroʊm/","ps":"noun","me":"group of related symptoms","mk":"증후군","ex":"Burnout syndrome affects many workers.","et":"번아웃 증후군이 많은 근로자에게 영향을 미친다.","t":"health"},{"w":"synergy","p":"/ˈsɪnərdʒi/","ps":"noun","me":"combined greater effect","mk":"시너지","ex":"The merger created strong synergy.","et":"합병이 강한 시너지를 만들었다.","t":"business"},{"w":"taxonomy","p":"/tækˈsɒnəmi/","ps":"noun","me":"classification system","mk":"분류학","ex":"The taxonomy of species is complex.","et":"종의 분류학이 복잡하다.","t":"science"},{"w":"transparency","p":"/trænsˈpærənsi/","ps":"noun","me":"openness and accountability","mk":"투명성","ex":"Government transparency builds public trust.","et":"정부 투명성이 국민 신뢰를 형성한다.","t":"society"},{"w":"traumatic","p":"/trɔːˈmætɪk/","ps":"adjective","me":"deeply disturbing","mk":"충격적인","ex":"The accident was highly traumatic.","et":"사고가 매우 충격적이었다.","t":"health"},{"w":"traverse","p":"/trəˈvɜːrs/","ps":"verb","me":"travel across or through","mk":"횡단하다","ex":"They traversed the mountain range.","et":"그들이 산맥을 횡단했다.","t":"travel"},{"w":"turbulent","p":"/ˈtɜːrbjʊlənt/","ps":"adjective","me":"unstable and chaotic","mk":"격동의","ex":"The region has a turbulent history.","et":"그 지역은 격동의 역사를 가지고 있다.","t":"society"},{"w":"unanimous","p":"/juːˈnænɪməs/","ps":"adjective","me":"fully in agreement","mk":"만장일치의","ex":"The vote was unanimous.","et":"투표가 만장일치였다.","t":"society"},{"w":"unwarranted","p":"/ʌnˈwɒrəntɪd/","ps":"adjective","me":"not justified","mk":"부당한","ex":"The criticism was entirely unwarranted.","et":"비판이 전적으로 부당했다.","t":"society"},{"w":"vanity","p":"/ˈvænɪti/","ps":"noun","me":"excessive pride in appearance","mk":"허영심","ex":"Vanity can cloud good judgment.","et":"허영심이 올바른 판단을 흐릴 수 있다.","t":"daily_life"},{"w":"venture","p":"/ˈvɛntʃər/","ps":"noun","me":"risky business undertaking","mk":"벤처","ex":"The joint venture proved profitable.","et":"합작 벤처가 수익성이 입증되었다.","t":"business"},{"w":"versatile","p":"/ˈvɜːrsətaɪl/","ps":"adjective","me":"adaptable to many functions","mk":"다재다능한","ex":"She is a versatile performer.","et":"그녀는 다재다능한 공연자이다.","t":"culture"},{"w":"biomass","p":"/ˈbaɪoʊmæs/","ps":"noun","me":"organic matter as fuel","mk":"바이오매스","ex":"Biomass is a renewable energy source.","et":"바이오매스는 재생 에너지원이다.","t":"environment"},{"w":"capsule","p":"/ˈkæpsjuːl/","ps":"noun","me":"small container or vehicle","mk":"캡슐","ex":"The capsule returned safely to Earth.","et":"캡슐이 안전하게 지구로 돌아왔다.","t":"science"},{"w":"cater","p":"/ˈkeɪtər/","ps":"verb","me":"provide what is wanted","mk":"충족시키다","ex":"The hotel caters to luxury travelers.","et":"호텔이 럭셔리 여행객을 충족시킨다.","t":"travel"},{"w":"commute","p":"/kəˈmjuːt/","ps":"verb","me":"travel regularly to work","mk":"통근하다","ex":"Millions commute to the city daily.","et":"수백만 명이 매일 도시로 통근한다.","t":"daily_life"},{"w":"concession","p":"/kənˈsɛʃən/","ps":"noun","me":"something yielded in negotiation","mk":"양보","ex":"Both sides made significant concessions.","et":"양측이 상당한 양보를 했다.","t":"business"},{"w":"confer","p":"/kənˈfɜːr/","ps":"verb","me":"grant or discuss","mk":"수여하다","ex":"The university conferred honorary degrees.","et":"대학이 명예 학위를 수여했다.","t":"education"},{"w":"disperse","p":"/dɪˈspɜːrs/","ps":"verb","me":"scatter in all directions","mk":"분산시키다","ex":"Police dispersed the large crowd.","et":"경찰이 대규모 군중을 분산시켰다.","t":"society"},{"w":"endow","p":"/ɪnˈdaʊ/","ps":"verb","me":"provide with a quality","mk":"부여하다","ex":"Nature endowed the region with beauty.","et":"자연이 그 지역에 아름다움을 부여했다.","t":"environment"},{"w":"envision","p":"/ɪnˈvɪʒən/","ps":"verb","me":"imagine as possible","mk":"구상하다","ex":"We envision a sustainable future.","et":"지속 가능한 미래를 구상한다.","t":"environment"}]